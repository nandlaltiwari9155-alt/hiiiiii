# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configuration
# SUPABASE_URL: Your Supabase Project API URL (e.g. https://xxxxxx.supabase.co)
SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY: The secret service role API key to securely bypass RLS rules for admin tasks server-side
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# JWT Secret for Admin Authentication
JWT_SECRET="super-secret-jwt-token-key-change-this-in-production"

# Admin credentials
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin_secure_password"

# Resend API Key for Email Notifications
RESEND_API_KEY=""

# FamPay UPI ID Configuration (Publicly accessible in client-side code)
VITE_FAMPAY_UPI_ID="APNA_FAMPAY_UPI_ID@fam"
VITE_PAYEE_NAME="NANDLAL"



